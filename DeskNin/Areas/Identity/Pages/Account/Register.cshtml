@page
@model Microsoft.AspNetCore.Identity.UI.V5.Pages.Account.Internal.RegisterModel
@{
    ViewData["Title"] = "Cadastrar";
}

<div class="desknin-auth-page min-vh-100 d-flex align-items-center justify-content-center p-4">
    <div class="w-100" style="max-width: 28rem;">
        @* Logo *@
        <div class="text-center mb-5">
            <div class="mb-3">
                <img src="~/img/logo.svg" alt="DeskNin" width="64" height="64"/>
            </div>
            <div class="fs-2 fw-semibold lh-sm">
                <span class="text-secondary">Desk</span><span class="text-primary">Nin</span>
            </div>
            <p class="mt-2 small text-body-secondary">Sistema de Gerenciamento de Chamados</p>
        </div>

        @* Register Card *@
        <div class="desknin-auth-card card shadow rounded-3 p-4 position-relative">
            <h2 class="fs-4 fw-semibold mb-1">Criar sua conta</h2>
            <p class="small text-body-secondary mb-4">Preencha os dados abaixo para se cadastrar no sistema</p>

            <form asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label small fw-medium">E-mail</label>
                    <div class="input-group">
                        <span class="input-group-text text-body-secondary">
                            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                                <polyline points="22,6 12,13 2,6"/>
                            </svg>
                        </span>
                        <input asp-for="Input.Email" type="email" class="form-control" placeholder="seu@email.com" autocomplete="username"/>
                    </div>
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label small fw-medium">Senha</label>
                    <div class="input-group">
                        <span class="input-group-text text-body-secondary">
                            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                            </svg>
                        </span>
                        <input asp-for="Input.Password" type="password" class="form-control" placeholder="••••••••" autocomplete="new-password"/>
                    </div>
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Input.ConfirmPassword" class="form-label small fw-medium">Confirmar senha</label>
                    <div class="input-group">
                        <span class="input-group-text text-body-secondary">
                            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                            </svg>
                        </span>
                        <input asp-for="Input.ConfirmPassword" type="password" class="form-control" placeholder="••••••••" autocomplete="new-password"/>
                    </div>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2 mb-4">Cadastrar</button>

                @if (Model.ExternalLogins?.Count > 0)
                {
                    <div class="position-relative my-4">
                        <hr/>
                        <span class="position-absolute top-50 start-50 translate-middle bg-body px-2 small text-body-secondary">ou</span>
                    </div>
                    <div class="d-grid gap-2">
                        @foreach (var provider in Model.ExternalLogins)
                        {
                            <form asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="mb-0">
                                <input type="hidden" name="provider" value="@provider.Name"/>
                                <button type="submit" class="btn btn-outline-secondary w-100">Cadastrar com @provider.DisplayName</button>
                            </form>
                        }
                    </div>
                }
            </form>

            <p class="text-center mt-4 mb-0 small text-body-secondary">
                Já tem uma conta? <a href="@Url.Page("/Account/Login", new { area = "Identity" })" class="link-primary text-decoration-none fw-medium">Entrar</a>
            </p>
        </div>

        <p class="text-center mt-4 small text-body-secondary">© @DateTime.Now.Year DeskNin - Sistema de Gerenciamento de Chamados</p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
