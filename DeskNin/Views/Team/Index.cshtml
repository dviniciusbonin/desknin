@model UserListViewModel
@{
    ViewData["Title"] = "Team";
    var addMemberError = TempData["AddMemberError"] as string;
}

@if (!string.IsNullOrEmpty(addMemberError))
{
    <div class="alert alert-danger alert-dismissible fade show rounded-3 mb-3" role="alert">
        @addMemberError
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<header class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h1 class="h3 fw-bold mb-1">Team</h1>
        <p class="text-body-secondary small mb-0">Manage team members</p>
    </div>
    <button type="button" class="btn btn-primary rounded-3 d-flex align-items-center gap-2" data-bs-toggle="modal" data-bs-target="#addMemberModal">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Add Member
    </button>
</header>

<div class="row g-3">
    @foreach (var u in Model.Users ?? Enumerable.Empty<UserViewModel>())
    {
        <div class="col-12 col-md-6 col-lg-4">
            <a asp-action="Edit" asp-route-id="@u.Id" class="text-decoration-none text-body">
            <div class="card border shadow-sm rounded-3 h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-start justify-content-between mb-3">
                        <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center flex-shrink-0 p-3">
                                <svg width="24" height="24" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            </div>
                        <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-2 py-1 small fw-medium">@u.Role</span>
                    </div>
                    <h3 class="h6 fw-bold mb-1 text-body">@u.Name</h3>
                    <p class="small text-body-secondary mb-3">@u.Email</p>
                    <hr class="my-3"/>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="small text-body-secondary">Tickets</span>
                        <span class="fw-bold">@u.TicketCount</span>
                    </div>
                </div>
            </div>
            </a>
        </div>
    }
</div>

<div class="modal fade" id="addMemberModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-3 border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-semibold">Add Member</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-2">
                <form asp-action="Index" method="post" autocomplete="off">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    <div class="mb-3">
                        <label for="add-Username" class="form-label">Name</label>
                        <input name="Username" id="add-Username" class="form-control rounded-2" required autocomplete="off"/>
                    </div>
                    <div class="mb-3">
                        <label for="add-Email" class="form-label">Email</label>
                        <input name="Email" id="add-Email" type="email" class="form-control rounded-2" required autocomplete="off"/>
                    </div>
                    <div class="mb-3">
                        <label for="add-Role" class="form-label">Role</label>
                        <select name="Role" id="add-Role" class="form-select rounded-2" required>
                            <option value="">-- Select --</option>
                            <option value="Admin">Admin</option>
                            <option value="Technical">Technical</option>
                            <option value="User">User</option>
                        </select>
                    </div>
                    <div class="mb-4">
                        <label class="form-label">Password</label>
                        <div class="input-group">
                            <input type="text" id="add-Password-display" class="form-control rounded-2 font-monospace" readonly/>
                            <input type="hidden" name="Password" id="add-Password"/>
                            <button type="button" class="btn btn-outline-secondary rounded-2" id="add-pwd-generate">Generate</button>
                            <button type="button" class="btn btn-outline-secondary rounded-2" id="add-pwd-copy">Copy</button>
                        </div>
                        <small class="text-body-secondary">Copy and send to the user</small>
                    </div>
                    <div class="d-flex gap-2 justify-content-end">
                        <button type="button" class="btn btn-outline-secondary rounded-2" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary rounded-2" id="add-submit">Add</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
    <script>
        @if (!string.IsNullOrEmpty(addMemberError))
        {
            <text>
            document.addEventListener('DOMContentLoaded', function () {
                new bootstrap.Modal(document.getElementById('addMemberModal')).show();
            });
            </text>
        }
        document.getElementById('addMemberModal').addEventListener('show.bs.modal', function () {
            document.getElementById('add-Username').value = '';
            document.getElementById('add-Email').value = '';
            document.getElementById('add-Role').value = '';
            document.getElementById('add-Password-display').value = '';
            document.getElementById('add-Password').value = '';
        });
        function generatePassword() {
            const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZabcdefghjkmnpqrstuvwxyz23456789!@@#$%';
            let pwd = '';
            for (let i = 0; i < 12; i++) pwd += chars.charAt(Math.floor(Math.random() * chars.length));
            return pwd;
        }
        document.getElementById('add-pwd-generate').addEventListener('click', function () {
            const pwd = generatePassword();
            document.getElementById('add-Password-display').value = pwd;
            document.getElementById('add-Password').value = pwd;
        });
        document.getElementById('add-pwd-copy').addEventListener('click', function () {
            const pwd = document.getElementById('add-Password-display').value;
            if (pwd) navigator.clipboard.writeText(pwd).then(function () { this.textContent = 'Copied!'; setTimeout(() => this.textContent = 'Copy', 1500); }.bind(this));
        });
        document.querySelector('#addMemberModal form').addEventListener('submit', function () {
            if (!document.getElementById('add-Password').value) {
                event.preventDefault();
                alert('Generate a password first');
                return false;
            }
        });
    </script>
}
